{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=webhookengine;Username=webhookengine;Password=webhookengine"
  },
  "WebhookEngine": {
    "Delivery": {
      "TimeoutSeconds": 30,
      "BatchSize": 10,
      "PollIntervalMs": 1000,
      "StaleLockMinutes": 5
    },
    "RetryPolicy": {
      "MaxRetries": 7,
      "BackoffSchedule": [5, 30, 120, 900, 3600, 21600, 86400]
    },
    "CircuitBreaker": {
      "FailureThreshold": 5,
      "CooldownMinutes": 5,
      "SuccessThreshold": 1
    },
    "DashboardAuth": {
      "AdminEmail": "admin@example.com",
      "AdminPassword": "changeme"
    },
    "Retention": {
      "DeliveredRetentionDays": 30,
      "DeadLetterRetentionDays": 90
    },
    "RateLimit": {
      "PermitLimit": 100,
      "ReplenishmentPeriodSeconds": 1,
      "TokensPerPeriod": 2,
      "QueueLimit": 0
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
