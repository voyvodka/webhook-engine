{
  "name": "@webhookengine/endpoint-manager",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Embeddable React portal for managing webhook endpoints — pairs with WebhookEngine self-hosted.",
  "license": "MIT",
  "homepage": "https://github.com/voyvodka/webhook-engine",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voyvodka/webhook-engine.git",
    "directory": "packages/endpoint-manager"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run clean && bun run build:css && tsup",
    "build:css": "tailwindcss -i src/styles.css -o dist/style.css --minify",
    "dev": "vite --config demo/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "10.5.0",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}