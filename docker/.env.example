# WebhookEngine Docker Compose Environment Variables
# Copy this file to .env and adjust values before running:
#   cp .env.example .env
#   docker compose -f docker/docker-compose.yml up -d

# Application port (default: 5100)
APP_PORT=5100

# PostgreSQL password (CHANGE THIS in production!)
POSTGRES_PASSWORD=webhookengine

# Dashboard admin credentials (CHANGE THESE in production!)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
